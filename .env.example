# ─────────────────────────────────────────────────────────────────────────────
# MediAgent — Environment Variables
#
# SETUP:
#   1. cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env — it is in .gitignore
#
# PRODUCTION NOTE:
#   In production, inject these as Kubernetes Secrets or AWS Secrets Manager
#   entries — do not use .env files in containerised deployments.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (Required) ──────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# ── Model Configuration (Optional) ───────────────────────────────────────────
# MVP:        gpt-4o-mini / text-embedding-3-small  (cost-optimised)
# Production: gpt-4o       / text-embedding-3-large  (quality-optimised)
# Air-gapped: llama3-70b   / bge-large-en-v1.5       (on-prem via vLLM)
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Production Database (Phase 1 upgrade — leave blank for MVP Excel mode) ───
# POSTGRES_URL=postgresql://user:password@localhost:5432/mediagent
# REDIS_URL=redis://localhost:6379/0

# ── Observability (Phase 3 — optional for MVP) ───────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...your-langsmith-key...
# LANGCHAIN_PROJECT=mediagent-production
# SENTRY_DSN=https://...@sentry.io/...

# ── Security (Production) ─────────────────────────────────────────────────────
# JWT_SECRET_KEY=...generate-with-openssl-rand-hex-32...
# ENCRYPTION_KEY=...AES-256-key-for-PII-at-rest...
